@model List<SV22T1020293.Models.Sales.OrderDetailViewInfo>
@using SV22T1020293.Models
@using SV22T1020293.Models.Partner

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var order = ViewBag.Order as SV22T1020293.Models.Sales.OrderViewInfo;
    var shipper = ViewBag.Shipper as Shipper;
    decimal totalAmount = Model?.Sum(x => x.TotalPrice) ?? 0;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h3 class="fw-bold mb-0">Chi tiết đơn hàng #@order?.OrderID</h3>
        <a asp-action="History" class="btn btn-outline-secondary">
            Quay lại
        </a>
    </div>

    @if (order == null)
    {
        <div class="alert alert-danger">
            Không tìm thấy thông tin đơn hàng.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <p class="mb-2"><strong>Mã đơn:</strong> #@order.OrderID</p>
                        <p class="mb-2"><strong>Ngày đặt:</strong> @order.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-2"><strong>Tỉnh/Thành:</strong> @order.DeliveryProvince</p>
                        <p class="mb-2"><strong>Địa chỉ giao:</strong> @order.DeliveryAddress</p>
                    </div>

                    <div class="col-md-6">
                        <p class="mb-2">
                            <strong>Trạng thái:</strong>
                            @if (order.Status == OrderStatusEnum.New)
                            {
                                <span class="badge bg-secondary">Chờ xác nhận</span>
                            }
                            else if (order.Status == OrderStatusEnum.Accepted)
                            {
                                <span class="badge bg-primary">Đã xác nhận</span>
                            }
                            else if (order.Status == OrderStatusEnum.Shipping)
                            {
                                <span class="badge bg-info text-dark">Đang giao</span>
                            }
                            else if (order.Status == OrderStatusEnum.Completed)
                            {
                                <span class="badge bg-success">Hoàn tất</span>
                            }
                            else if (order.Status == OrderStatusEnum.Cancelled)
                            {
                                <span class="badge bg-danger">Đã hủy</span>
                            }
                            else if (order.Status == OrderStatusEnum.Rejected)
                            {
                                <span class="badge bg-warning text-dark">Từ chối</span>
                            }
                            else
                            {
                                <span class="badge bg-dark">Không xác định</span>
                            }
                        </p>

                        @if (order.AcceptTime.HasValue)
                        {
                            <p class="mb-2"><strong>Thời gian xác nhận:</strong> @order.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        }

                        @if (order.ShippedTime.HasValue)
                        {
                            <p class="mb-2"><strong>Thời gian giao:</strong> @order.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        }

                        @if (order.FinishedTime.HasValue)
                        {
                            <p class="mb-2"><strong>Hoàn tất lúc:</strong> @order.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        }

                        @if (order.ShipperID.HasValue && order.ShipperID.Value > 0)
                        {
                            <div class="mt-3 p-3 rounded-3 border bg-light">
                                <h6 class="fw-bold mb-2">Thông tin giao hàng</h6>

                                <p class="mb-2"><strong>Mã shipper:</strong> #@order.ShipperID</p>

                                @if (shipper != null)
                                {
                                    <p class="mb-2"><strong>Đơn vị giao hàng:</strong> @shipper.ShipperName</p>

                                    @if (!string.IsNullOrWhiteSpace(shipper.Phone))
                                    {
                                        <p class="mb-0"><strong>SĐT shipper:</strong> @shipper.Phone</p>
                                    }
                                    else
                                    {
                                        <p class="mb-0 text-muted"><em>Chưa có số điện thoại shipper</em></p>
                                    }
                                }
                                else
                                {
                                    <p class="mb-0 text-muted"><em>Không tìm thấy thông tin shipper</em></p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="mb-0 fw-semibold">Danh sách sản phẩm</h5>
            </div>
            <div class="card-body p-0">
                @if (Model == null || !Model.Any())
                {
                    <div class="p-4 text-muted">
                        Không có sản phẩm nào trong đơn hàng này.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                                     alt="@item.ProductName"
                                                     style="width:70px;height:70px;object-fit:cover;border-radius:12px;border:1px solid #eee;" />
                                                <div>
                                                    <div class="fw-semibold">@item.ProductName</div>
                                                    <small class="text-muted">Mã SP: #@item.ProductID</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                                        <td class="text-end fw-semibold">@item.TotalPrice.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th colspan="3" class="text-end">Tổng cộng:</th>
                                    <th class="text-end text-danger fs-5">@totalAmount.ToString("N0") đ</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>