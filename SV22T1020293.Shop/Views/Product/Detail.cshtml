@model SV22T1020293.Models.Catalog.Product
@using SV22T1020293.Models.Catalog

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var photo = string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo;
}

<div class="container py-4 main-content">

    <div class="row mb-4 justify-content-center">
        <div class="col-12 text-center">
            <h3 class="fw-bold mb-1" style="color: var(--text-main);">Chi tiết sản phẩm</h3>
            <p class="text-muted">Thông tin đầy đủ về sản phẩm bạn đang quan tâm</p>
        </div>
    </div>

    <div class="row justify-content-center g-4">

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-3 product-detail-card h-100"
                 style="background-color: var(--bg-white);">

                <div class="product-detail-image-wrapper rounded-4 overflow-hidden">
                    <img src="~/images/products/@photo"
                         alt="@Model.ProductName"
                         class="img-fluid w-100 product-detail-main-image" />
                </div>

                <div class="mt-3 text-center">
                    <small class="text-muted">Hình ảnh sản phẩm</small>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 p-4 product-detail-card h-100"
                 style="background-color: var(--bg-white);">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h2 class="fw-bold mb-2 product-detail-title">@Model.ProductName</h2>

                        @if (Model.IsSelling)
                        {
                            <span class="badge rounded-pill px-3 py-2 product-status-badge bg-success-subtle text-success-emphasis">
                                <i class="bi bi-check-circle-fill me-1"></i> Đang bán
                            </span>
                        }
                        else
                        {
                            <span class="badge rounded-pill px-3 py-2 product-status-badge bg-secondary-subtle text-secondary-emphasis">
                                <i class="bi bi-x-circle-fill me-1"></i> Ngừng bán
                            </span>
                        }
                    </div>

                    <div class="text-end">
                        <div class="product-detail-price">
                            @Model.Price.ToString("N0") đ
                        </div>
                    </div>
                </div>

                <hr class="text-muted opacity-10 my-3">

                <div class="row py-2 align-items-center">
                    <div class="col-sm-4 info-label">
                        Mã sản phẩm
                    </div>
                    <div class="col-sm-8 fw-semibold">#@Model.ProductID</div>
                </div>
                <hr class="text-muted opacity-10 my-2">

                <div class="row py-2 align-items-center">
                    <div class="col-sm-4 info-label">
                        Đơn vị tính
                    </div>
                    <div class="col-sm-8 fw-medium">
                        @if (string.IsNullOrWhiteSpace(Model.Unit))
                        {
                            <span class="text-muted fst-italic">Chưa cập nhật</span>
                        }
                        else
                        {
                            <span>@Model.Unit</span>
                        }
                    </div>
                </div>
                <hr class="text-muted opacity-10 my-2">

                <div class="row py-2 align-items-center">
                    <div class="col-sm-4 info-label">
                        Loại hàng
                    </div>
                    <div class="col-sm-8 fw-medium">
                        @if (string.IsNullOrWhiteSpace(ViewBag.CategoryName))
                        {
                            <span class="text-muted fst-italic">Chưa cập nhật</span>
                        }
                        else
                        {
                            <span>@ViewBag.CategoryName</span>
                        }
                    </div>
                </div>
                <hr class="text-muted opacity-10 my-2">

                <div class="row py-2 align-items-center">
                    <div class="col-sm-4 info-label">
                        Nhà cung cấp
                    </div>
                    <div class="col-sm-8 fw-medium">
                        @if (string.IsNullOrWhiteSpace(ViewBag.SupplierName))
                        {
                            <span class="text-muted fst-italic">Chưa cập nhật</span>
                        }
                        else
                        {
                            <span>@ViewBag.SupplierName</span>
                        }
                    </div>
                </div>

                <hr class="text-muted opacity-10 my-3">

                <div class="mb-4">
                    <h5 class="fw-bold mb-3" style="color: var(--text-main);">
                        <i class="bi bi-card-text me-2 text-primary"></i>
                        Mô tả sản phẩm
                    </h5>

                    <div class="product-description-box">
                        @if (string.IsNullOrWhiteSpace(Model.ProductDescription))
                        {
                            <span class="text-muted fst-italic">Chưa có mô tả cho sản phẩm này.</span>
                        }
                        else
                        {
                            <p class="mb-0 lh-lg text-muted">@Model.ProductDescription</p>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-auto pt-4">

                    <a href="~/Product" class="btn btn-light rounded-3 px-4 py-2 border">
                        <i class="bi bi-arrow-left me-2"></i> Quay lại
                    </a>

                    @if (Model.IsSelling)
                    {
                        <a href="~/Cart/BuyNow/@Model.ProductID" class="btn btn-success rounded-3 px-4 py-2">
                            <i class="bi bi-lightning-charge-fill me-2"></i> Mua ngay
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary rounded-3 px-4 py-2" disabled>
                            <i class="bi bi-ban me-2"></i> Tạm hết hàng
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>