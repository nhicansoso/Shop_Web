@model SV22T1020293.Models.Common.PagedResult<SV22T1020293.Models.Catalog.Product>

<div class="mb-3 text-muted">
    Có <strong>@Model.RowCount</strong> sản phẩm
</div>

<div class="row g-4">

    @if (Model.DataItems == null || !Model.DataItems.Any())
    {
        <div class="col-12 text-center text-muted">
            Không có sản phẩm
        </div>
    }
    else
    {
        foreach (var item in Model.DataItems)
        {
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0">

                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">
                        <h6 class="fw-bold">@item.ProductName</h6>

                        <p class="text-muted small">
                            @item.Unit
                        </p>

                        <div class="mt-auto">
                            <div class="fw-bold text-danger fs-5 mb-3">
                                @item.Price.ToString("N0") đ
                            </div>

                            <div class="d-grid gap-2">

                                <a href="/Product/Detail/@item.ProductID"
                                   class="btn btn-outline-dark rounded-3">
                                    <i class="bi bi-eye me-1"></i> Xem chi tiết
                                </a>

                                <a href="/Cart/BuyNow/@item.ProductID"
                                   class="btn btn-primary rounded-3">
                                    <i class="bi bi-cart-plus me-1"></i> Mua ngay
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        }
    }

</div>

@if (Model.RowCount > 0)
{
    <div class="text-center mt-4">
        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.IsCurrent)
            {
                <span class="btn btn-primary btn-sm">@p.Page</span>
            }
            else if (p.IsEllipsis)
            {
                <span class="btn btn-light btn-sm">...</span>
            }
            else
            {
                <a href="javascript:;"
                   class="btn btn-outline-primary btn-sm"
                   onclick="paginationSearch(null, document.getElementById('formSearch'), @p.Page)">
                    @p.Page
                </a>
            }
        }
    </div>
}