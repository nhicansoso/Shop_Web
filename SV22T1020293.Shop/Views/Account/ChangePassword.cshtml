@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-2 main-content">

    <div class="row mb-3 justify-content-center">
        <div class="col-12 text-center">
            <h3 class="fw-bold mb-1" style="color: var(--text-main);">Đổi mật khẩu</h3>
            <p class="text-muted">Cập nhật mật khẩu để bảo mật tài khoản của bạn</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7 mb-4">

            <div class="card shadow-sm border-0 rounded-4 p-3 p-md-4 profile-card" style="background-color: var(--bg-white);">

                <!-- Header -->
                <div class="mb-4 pb-3 border-bottom border-light">
                    <h5 class="fw-bold m-0" style="color: var(--text-main);">Thông tin mật khẩu</h5>
                </div>


                <div class="mb-3">
                    @if (ViewData.ModelState.TryGetValue(string.Empty, out var entry))
                    {
                        foreach (var error in entry.Errors)
                        {
                            <div class="alert @(error.ErrorMessage.Contains("thành công") ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                                <i class="bi @(error.ErrorMessage.Contains("thành công") ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                                @error.ErrorMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                    }
                </div>

                <form asp-action="ChangePassword" asp-controller="Account" method="post">

                    <div class="row g-3">

                        <!-- Mật khẩu cũ -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mật khẩu cũ</label>
                            <input type="password" asp-for="OldPassword" class="form-control rounded-3" placeholder="Nhập mật khẩu cũ" />
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <!-- Mật khẩu mới -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mật khẩu mới</label>
                            <input type="password" asp-for="NewPassword" class="form-control rounded-3" placeholder="Nhập mật khẩu mới" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <!-- Xác nhận mật khẩu mới -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
                            <input type="password" asp-for="ConfirmPassword" class="form-control rounded-3" placeholder="Nhập lại mật khẩu" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Nút hành động -->
                        <div class="col-12 mt-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="~/" class="btn btn-light rounded-3 px-4">
                                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                                </a>
                                <button type="submit" class="btn btn-primary rounded-3 px-4">
                                    <i class="bi bi-check2-circle me-1"></i> Lưu thay đổi
                                </button>
                            </div>
                        </div>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>