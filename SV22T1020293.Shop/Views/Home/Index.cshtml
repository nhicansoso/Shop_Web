@model List<SV22T1020293.Models.Catalog.Product>

<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-md-6">
            <p class="text-muted fs-5" >
                "Nơi tinh hoa hội tụ, khẳng định vị thế độc bản."
            </p>
            <p class="text-muted fs-5" >
                Chúng tôi kiến tạo chuẩn mực mới cho phong cách sống thượng lưu thông qua những tạo tác thủ công tinh xảo.
            </p>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h3 class="fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">
                Sản phẩm nổi bật
            </h3>
        </div>
        <a href="/Product" class="header-link text-decoration-none">
            Khám phá tất cả <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="row g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="mb-3 display-1 text-muted"><i class="bi bi-box-seam"></i></div>
                <p class="text-muted">Hiện chưa có sản phẩm nào được cập nhật.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Take(8))
            {
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 shadow-sm border-0">

                        <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">
                            <h6 class="fw-bold">@item.ProductName</h6>

                            <p class="text-muted small">
                                @item.Unit
                            </p>

                            <div class="mt-auto">
                                <div class="fw-bold text-danger fs-5 mb-3">
                                    @item.Price.ToString("N0") đ
                                </div>

                                <div class="d-grid gap-2">
                                    <a href="/Product/Detail/@item.ProductID"
                                       class="btn btn-outline-dark rounded-3">
                                        <i class="bi bi-eye me-1"></i> Xem chi tiết
                                    </a>

                                    <a href="/Cart/BuyNow/@item.ProductID"
                                       class="btn btn-primary rounded-3">
                                        <i class="bi bi-cart-plus me-1"></i> Mua ngay
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
    </div>
</div>