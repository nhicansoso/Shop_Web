@model List<SV22T1020293.Models.Sales.OrderDetailViewInfo>

@{
    ViewData["Title"] = "Thanh toán";
    decimal totalAmount = 0;
    foreach (var item in Model)
    {
        totalAmount += item.Quantity * item.SalePrice;
    }
}

<style>
    .cart-item-scroll {
        max-height: 240px;
        overflow-y: auto; 
        padding-right: 8px;
    }
        .cart-item-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .cart-item-scroll::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .cart-item-scroll::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 10px;
        }

            .cart-item-scroll::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8;
            }

    .product-name-full {
        white-space: normal;
        word-wrap: break-word; 
        overflow: visible;
        text-overflow: clip;
    }
</style>

<div class="container py-5">

    <form asp-controller="Cart" asp-action="CreateOrder" method="post">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 rounded-3">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="bi bi-truck me-2 text-primary"></i>Thông tin giao hàng
                        </h5>
                    </div>

                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold small text-uppercase text-muted">
                                    Tỉnh/Thành phố <span class="text-danger">*</span>
                                </label>
                                <select name="province" class="form-select rounded-3">
                                    <option value="">-- Chọn tỉnh/thành phố --</option>
                                    <option>Thừa Thiên Huế</option>
                                    <option>Đà Nẵng</option>
                                    <option>Quảng Trị</option>
                                    <option>Quảng Bình</option>
                                    <option>Hà Nội</option>
                                    <option>TP Hồ Chí Minh</option>
                                </select>
                                @Html.ValidationMessage("province", "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-semibold small text-uppercase text-muted">
                                    Địa chỉ chi tiết <span class="text-danger">*</span>
                                </label>
                                <textarea name="address"
                                          class="form-control rounded-3"
                                          rows="3"
                                          placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                                @Html.ValidationMessage("address", "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <a href="~/Cart/Index" class="text-decoration-none text-muted small">
                                <i class="bi bi-chevron-left"></i> Quay lại giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 rounded-3 bg-light">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="fw-bold mb-0 text-dark">Tóm tắt đơn hàng</h5>
                    </div>

                    <div class="card-body p-4">
                        <div class="mb-3 d-flex justify-content-between">
                            <span class="text-muted">Số lượng sản phẩm:</span>
                            <span class="fw-bold">@Model.Count</span>
                        </div>

                        <div class="cart-item-scroll mb-3">
                            @foreach (var item in Model)
                            {
                                var amount = item.Quantity * item.SalePrice;
                                <div class="d-flex justify-content-between align-items-start mb-2 pb-2 border-bottom border-white">
                                    <div class="small product-name-full me-3">
                                        <span class="fw-medium text-dark">@item.ProductName</span>
                                        <div class="text-muted small">SL: @item.Quantity</div>
                                    </div>
                                    <div class="small fw-bold text-end" style="min-width: 90px;">
                                        @amount.ToString("N0")<small>đ</small>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2 mb-4">
                            <span class="fw-bold text-dark fs-5">Tổng cộng:</span>
                            <span class="fw-bold text-danger fs-4">@totalAmount.ToString("N0") đ</span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg py-3 rounded-3 fw-bold shadow-sm">
                                <i class="bi bi-check2-circle me-2"></i>Xác nhận đặt hàng
                            </button>
                        </div>

                        <p class="text-center text-muted small mt-3 italic">
                            <i class="bi bi-shield-check"></i> Thanh toán an toàn & bảo mật
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>