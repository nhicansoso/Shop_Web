@model Product
@using SV22T1020293.Models.Catalog
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveData" enctype="multipart/form-data">

                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   asp-for="ProductName"
                                   class="form-control"
                                   placeholder="" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select"
                                    asp-for="CategoryID"
                                    asp-items="await SelectListHelper.Categories()">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select"
                                    asp-for="SupplierID"
                                    asp-items="await SelectListHelper.Suppliers()">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text"
                                   asp-for="Unit"
                                   class="form-control"
                                   placeholder="" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="number"
                                   asp-for="Price"
                                   class="form-control money-input"
                                   placeholder=""
                                   min="0" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       asp-for="IsSelling"
                                       type="checkbox"
                                       id="IsSelling" />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="mt-2">
                                @if (!string.IsNullOrWhiteSpace(Model.Photo))
                                {
                                    <img id="imgPreview"
                                         src="~/images/products/@Model.Photo"
                                         class="img-thumbnail"
                                         style="max-height: 160px;" />
                                }
                                else
                                {
                                    <img id="imgPreview"
                                         src="~/images/products/nophoto.png"
                                         class="img-thumbnail"
                                         style="max-height: 160px;" />
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control"
                                      asp-for="ProductDescription"
                                      rows="3"
                                      placeholder=""></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9 offset-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@{
    //if (Model.ProductId > 0) {
    if (Model.ProductID > 0)
    {
        var photos = ViewBag.ProductPhotos as List<ProductPhoto> ?? new List<ProductPhoto>();
        var attributes = ViewBag.ProductAttributes as List<ProductAttribute> ?? new List<ProductAttribute>();

        ViewBag.ProductID = Model.ProductID;
        await Html.RenderPartialAsync("ListPhotos", photos);

        ViewBag.ProductID = Model.ProductID;
        await Html.RenderPartialAsync("ListAttributes", attributes);
    }
    // }
}

@section Scripts {
    <script>
        function previewImage(input) {
            var preview = document.getElementById("imgPreview");
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}